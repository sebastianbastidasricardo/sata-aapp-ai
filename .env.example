# Configuración necesaria para correr SATA localmente

# API Key de Google Gemini (Obtenla en https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=

# Las credenciales de Supabase pueden configurarse directamente en la UI de la app 
# una vez esté corriendo, pero puedes definirlas aquí si lo prefieres para que se carguen por defecto.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
